---
import InfiniteLogoMarquee from './InfiniteLogoMarquee.wrapper.astro'
import { cn } from '@/lib/core/utils'

interface Props {
	title: string
	subtitle: string
}

const { title, subtitle } = Astro.props
---

<section
	class={cn(
		'relative overflow-hidden',
		'py-12 sm:py-16 lg:py-20',
		'bg-gradient-to-br from-white via-brand-gray-soft/80 to-brand-blue-light/40',
		'dark:from-brand-charcoal dark:via-brand-charcoal dark:to-brand-charcoal-dark',
	)}
>
	{/* Decorative elements */}
	<div class="pointer-events-none absolute inset-0 opacity-30">
		<div
			class="bg-brand-blue/20 absolute top-0 left-0 h-96 w-96 rounded-full blur-3xl"
		>
		</div>
		<div
			class="bg-brand-green/20 absolute right-0 bottom-0 h-96 w-96 rounded-full blur-3xl"
		>
		</div>
	</div>

	<div class="relative mx-auto max-w-7xl px-6 lg:px-12">
		{/* Header */}
		<div class="mx-auto mb-12 max-w-3xl text-center">
			<h2
				class={cn(
					'mb-4 text-4xl font-bold tracking-tight',
					'sm:text-5xl lg:text-6xl',
					'bg-gradient-to-br from-brand-charcoal via-brand-charcoal to-brand-blue',
					'dark:from-white dark:via-white dark:to-brand-blue-light',
					'bg-clip-text text-transparent',
				)}
			>
				{title}
			</h2>

			<p
				class={cn(
					'text-lg leading-relaxed',
					'sm:text-xl lg:text-2xl',
					'text-brand-charcoal/70 dark:text-white/70',
				)}
			>
				{subtitle}
			</p>
		</div>

		{/* Logo Marquee */}
		<InfiniteLogoMarquee speed="normal" />

		{/* Bottom accent */}
		<div class="mt-12 text-center">
			<div
				class={cn(
					'mx-auto inline-flex items-center gap-2 rounded-full',
					'bg-white/50 dark:bg-brand-charcoal/50',
					'backdrop-blur-sm',
					'border border-white/20 dark:border-white/10',
					'px-6 py-3',
					'text-sm font-medium',
					'text-brand-charcoal/60 dark:text-white/60',
				)}
			>
				<svg
					class="text-brand-green h-5 w-5"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M5 13l4 4L19 7"></path>
				</svg>
				<span>Trusted by industry leaders since 2020</span>
			</div>
		</div>
	</div>
</section>
